{
  "name": "gestion-comercios",
  "private": true,
  "version": "0.2.27",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "build:win": "npm run tauri build",
    "build:win:catalog": "npm run tauri build -- --config src-tauri/tauri.conf.catalog.json",
    "release": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/publicar.ps1",
    "license:keys": "node scripts/gen-license-keys.mjs",
    "license:create": "node scripts/license-admin.mjs create",
    "license:list": "node scripts/license-admin.mjs list",
    "test:e2e": "playwright test",
    "test:e2e:stress": "playwright test --project=stress",
    "test:e2e:report": "playwright show-report tests/reports/html",
    "qa": "node scripts/qa.mjs",
    "qa:repeat": "node scripts/qa-repeat.mjs",
    "qa:verify": "node scripts/qa-repeat.mjs"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-sql": "^2.4.0",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "lucide-react": "^1.17.0",
    "qrcode": "^1.5.4",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.16.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/vite": "^4.3.0",
    "@tauri-apps/cli": "^2",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "tailwindcss": "^4.3.0",
    "typescript": "~5.8.3",
    "vite": "^7.0.4"
  }
}
