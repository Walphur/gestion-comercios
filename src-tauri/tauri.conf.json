{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Gestión Comercios",
  "version": "0.1.0",
  "identifier": "com.gestioncomercios.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Gestión Comercios",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 680,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEE0NDhENEQxM0FBOUQ3NEMKUldSTTE2azYwZFJJcEtKc2RWaTFGODhlME1yNldLSnUzUis5WlVtYWYzUURwaXFvc240R3RIa3oK",
      "endpoints": [
        "https://github.com/Walphur/gestion-comercios/releases/latest/download/latest.json"
      ],
      "dialog": false
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "../productos_supermercado.csv": "productos_supermercado.csv"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
